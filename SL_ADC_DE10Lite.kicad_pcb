	(gr_text "\n"
		(at 178.04 137.46 0)
		(layer "B.Cu")
		(uuid "a1eebdf6-b7c1-4a50-bcfd-6b28ee1b784b")
		(effects
			(font
				(size 1.27 1.27)
			)
		)
	)
	(gr_text "We might wanna move this cap down to\nmake clearance for the pins you'll have to \nroute, you'll figure it out when you begin\nrouting the rest of the pins"
		(at 101 116 0)
		(layer "F.SilkS")
		(uuid "8cd638b6-e5dc-43fe-93d3-e6ac4c103e99")
		(effects
			(font
				(size 0.5 0.5)
				(thickness 0.125)
				(bold yes)
			)
			(justify left bottom)
		)
	)
	(gr_text "See comment for the\ncapacitor on the right side"
		(at 107.5 109 0)
		(layer "F.SilkS")
		(uuid "65e85350-81a1-47c1-b629-537fdc5dd8fb")
		(effects
			(font
				(size 0.5 0.5)
				(thickness 0.125)
				(bold yes)
			)
			(justify left bottom)
		)
	)
	(gr_text "Don't bother with this\nlong trace connecting\nagnd on these capacitors\nto the ground via under the\nADC. The ground plane will\nprovide that path just fine.\nOnly do this for connecting to \none of the ADC's ground pins"
		(at 114 98.5 0)
		(layer "F.SilkS")
		(uuid "82b1888a-914a-4cb2-a902-c8b780c84b7e")
		(effects
			(font
				(size 0.5 0.5)
				(thickness 0.125)
				(bold yes)
			)
			(justify left bottom)
		)
	)
	(gr_text "Not sure what these resistors are for"
		(at 117.5 129 0)
		(layer "F.SilkS")
		(uuid "3e2ef68a-cca5-4f8c-97d6-d667b631873f")
		(effects
			(font
				(size 0.5 0.5)
				(thickness 0.125)
				(bold yes)
			)
			(justify left bottom)
		)
	)
	(gr_text "Might move this cap to the bottom of the PCB\nThe datasheet suggeested it and I think it will \nInterfere with your routing in this postition.\n\nEither move further away or move to bottom of PCB"
		(at 136 128 0)
		(layer "F.SilkS")
		(uuid "1a63b306-051b-4482-a59b-53d73552ca0a")
		(effects
			(font
				(size 0.5 0.5)
				(thickness 0.125)
				(bold yes)
			)
			(justify left bottom)
		)
	)
	(gr_text "Love that you put the ground plane\nsplit vias here, wonderful!\n"
		(at 141 116 0)
		(layer "F.SilkS")
		(uuid "76880147-b608-4b0b-b6b0-96a46918ce76")
		(effects
			(font
				(size 0.5 0.5)
				(thickness 0.125)
				(bold yes)
			)
			(justify left bottom)
		)
	)
	(gr_text "If you put the AVDD-||-AGND capacitor\nto the left of the REFAP-||-AGND capacitor, \nyou'd be able to avoid using a via to route \nAVDD and get a cleaner route"
		(at 154.5 109.5 0)
		(layer "F.SilkS")
		(uuid "71176f8a-8d3f-44a5-aa44-5d62be564432")
		(effects
			(font
				(size 0.5 0.5)
				(thickness 0.125)
				(bold yes)
			)
			(justify left bottom)
		)
	)
